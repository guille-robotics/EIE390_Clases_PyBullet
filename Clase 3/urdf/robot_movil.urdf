<?xml version="1.0"?>
<robot name="robot_movil_14kg">

    <material name="azul">
        <color rgba="0.2 0.2 0.8 1"/>
    </material>
    <material name="negro">
        <color rgba="0.1 0.1 0.1 1"/>
    </material>

    <link name="chasis">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.4 0.25 0.1"/>
            </geometry>
            <material name="azul"/>
        </visual>
        
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.4 0.25 0.1"/>
            </geometry>
        </collision>
        
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10.0"/>
            <inertia ixx="0.0604" ixy="0.0" ixz="0.0" 
                     iyy="0.1416" iyz="0.0" 
                     izz="0.1854"/>
        </inertial>
    </link>

    <link name="rueda_delantera_derecha">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
            <material name="negro"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0017" ixy="0.0" ixz="0.0" 
                     iyy="0.0017" iyz="0.0" 
                     izz="0.0032"/>
        </inertial>
    </link>

    <joint name="joint_rueda_dd" type="continuous">
        <parent link="chasis"/>
        <child link="rueda_delantera_derecha"/>
        <origin xyz="0.15 -0.15 -0.05" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rueda_delantera_izquierda">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
            <material name="negro"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0017" ixy="0.0" ixz="0.0" iyy="0.0017" iyz="0.0" izz="0.0032"/>
        </inertial>
    </link>

    <joint name="joint_rueda_di" type="continuous">
        <parent link="chasis"/>
        <child link="rueda_delantera_izquierda"/>
        <origin xyz="0.15 0.15 -0.05" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rueda_trasera_derecha">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
            <material name="negro"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0017" ixy="0.0" ixz="0.0" iyy="0.0017" iyz="0.0" izz="0.0032"/>
        </inertial>
    </link>

    <joint name="joint_rueda_td" type="continuous">
        <parent link="chasis"/>
        <child link="rueda_trasera_derecha"/>
        <origin xyz="-0.15 -0.15 -0.05" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

    <link name="rueda_trasera_izquierda">
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
            <material name="negro"/>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder length="0.04" radius="0.08"/>
            </geometry>
        </collision>
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1.0"/>
            <inertia ixx="0.0017" ixy="0.0" ixz="0.0" iyy="0.0017" iyz="0.0" izz="0.0032"/>
        </inertial>
    </link>

    <joint name="joint_rueda_ti" type="continuous">
        <parent link="chasis"/>
        <child link="rueda_trasera_izquierda"/>
        <origin xyz="-0.15 0.15 -0.05" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
    </joint>

</robot>