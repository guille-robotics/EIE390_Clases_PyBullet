<?xml version="1.0"?>
<robot name="pendulo_simple">

  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.1"/> 
      </geometry>
      <material name="azul">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    
    <collision>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
    </collision>
    
    <inertial>
      <mass value="2.0"/> <inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/> 
    </inertial>
  </link>

  <link name="brazo_link">
    <visual>
      <geometry>
        <cylinder radius="0.05" length="0.4"/>
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <material name="rojo">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.05" length="0.4"/>
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="0.5"/> <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <inertia ixx="0.005" ixy="0" ixz="0" iyy="0.005" iyz="0" izz="0.005"/>
    </inertial>
  </link>

  <joint name="articulacion_hombro" type="revolute"> <parent link="base_link"/>
    <child link="brazo_link"/>
    
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
    
    <axis xyz="0 1 0"/>
    
    <limit lower="-1.57" upper="1.57" effort="10" velocity="3"/>
  </joint>

</robot>